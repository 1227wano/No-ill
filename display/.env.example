# ==============================================================================
# 리액트 프로젝트 환경 변수 가이드 (.env.example)
# 실제 설정은 .env 파일을 생성하여 작성하며, .env 파일은 Git에 포함하지 않습니다.
# ==============================================================================

# 1. API 설정
# ------------------------------------------------------------------------------
# Vite 사용 시: VITE_ 접두사 사용
# CRA 사용 시 : REACT_APP_ 접두사 사용
VITE_API_BASE_URL=https://api.example.com
VITE_API_TIMEOUT=5000

# 2. 인증 설정
# ------------------------------------------------------------------------------
# Mock 인증 활성화 (개발 시 true, 실제 API 연동 시 false)
VITE_USE_MOCK_AUTH=true

# 3. WebSocket 설정
# ------------------------------------------------------------------------------
# 낙상 알림 WebSocket URL
VITE_WS_URL=ws://localhost:8080

# 4. 공공데이터포털 API 설정
# ------------------------------------------------------------------------------
# https://www.data.go.kr 에서 API 키 발급
# 기상청_단기예보 조회서비스
VITE_DATA_GO_KR_API_KEY=your_decoding_key_here
# 격자 좌표 (기본값: 서울)
VITE_WEATHER_NX=60
VITE_WEATHER_NY=127
# 에어코리아 측정소명 (기본값: 종로구)
VITE_AIR_STATION_NAME=종로구

# 5. Firebase (FCM) 설정 - 영상 통화 푸시 알림용
# ------------------------------------------------------------------------------
# Firebase 콘솔에서 프로젝트 설정 → 일반 → 웹 앱 → SDK 설정
# 필수: 모든 Firebase 설정이 없으면 영상 통화 기능이 동작하지 않습니다.

# Firebase 프로젝트 API 키
VITE_FIREBASE_API_KEY=your_firebase_api_key

# Firebase 인증 도메인 (예: your-project.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase 프로젝트 ID
VITE_FIREBASE_PROJECT_ID=your-project-id

# Firebase 메시징 발신자 ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase 앱 ID
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Firebase 웹 푸시 인증서 키 (VAPID Key)
# Firebase 콘솔 → Cloud Messaging → 웹 푸시 인증서 → 키 페어 생성
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# 6. Service Worker 설정 (선택사항)
# ------------------------------------------------------------------------------
# Service Worker 파일 경로 (기본값: /firebase-messaging-sw.js)
# 커스텀 경로가 필요한 경우에만 설정
# VITE_SW_PATH=/custom-path/firebase-messaging-sw.js

# 7. OpenVidu 설정 (선택사항)
# ------------------------------------------------------------------------------
# OpenVidu 서버 URL (개발 환경)
# 프로덕션에서는 백엔드 API를 통해 관리하므로 설정 불필요
# VITE_OPENVIDU_SERVER_URL=https://localhost:4443
# VITE_OPENVIDU_SERVER_SECRET=MY_SECRET

# ==============================================================================
# 🔴 주의사항
# ==============================================================================
# 1. .env 파일은 절대 Git에 커밋하지 마세요!
# 2. Firebase 설정은 모두 필수입니다. 하나라도 누락되면 에러가 발생합니다.
# 3. VAPID Key는 Firebase 콘솔에서 새로 생성해야 합니다.
# 4. 프로덕션 환경에서는 실제 API URL과 Firebase 설정을 사용하세요.
# 5. API_TIMEOUT 단위는 밀리초(ms)입니다. (5000 = 5초)
# ==============================================================================

# ==============================================================================
# 📝 설정 가이드
# ==============================================================================
#
# [Firebase 설정 방법]
# 1. Firebase 콘솔 접속: https://console.firebase.google.com
# 2. 프로젝트 선택 또는 생성
# 3. 프로젝트 설정 → 일반 → 내 앱 → 웹 앱 추가
# 4. SDK 설정 정보 복사 → .env 파일에 붙여넣기
# 5. Cloud Messaging 탭 → 웹 푸시 인증서 → 키 페어 생성
# 6. 생성된 VAPID Key → .env의 VITE_FIREBASE_VAPID_KEY에 붙여넣기
#
# [개발 환경 설정 예시]
# VITE_API_BASE_URL=http://localhost:8080
# VITE_USE_MOCK_AUTH=true
# VITE_WS_URL=ws://localhost:8080
#
# [프로덕션 환경 설정 예시]
# VITE_API_BASE_URL=https://api.yourservice.com
# VITE_USE_MOCK_AUTH=false
# VITE_WS_URL=wss://api.yourservice.com
#
# ==============================================================================
