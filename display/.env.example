# ==============================================================================
# 리액트 프로젝트 환경 변수 가이드 (.env.example)
# 실제 설정은 .env 파일을 생성하여 작성하며, .env 파일은 Git에 포함하지 않습니다.
# ==============================================================================

# 1. API 설정
# ------------------------------------------------------------------------------
# Vite 사용 시: VITE_ 접두사 사용
# CRA 사용 시 : REACT_APP_ 접두사 사용
VITE_API_BASE_URL=https://api.example.com
VITE_API_TIMEOUT=5000

# 2. 인증 설정
# ------------------------------------------------------------------------------
# Mock 인증 활성화 (개발 시 true, 실제 API 연동 시 false)
VITE_USE_MOCK_AUTH=true

# 3. WebSocket 설정
# ------------------------------------------------------------------------------
# 낙상 알림 WebSocket URL
VITE_WS_URL=ws://localhost:8080

# 4. 공공데이터포털 API 설정
# ------------------------------------------------------------------------------
# https://www.data.go.kr 에서 API 키 발급
# 기상청_단기예보 조회서비스
VITE_DATA_GO_KR_API_KEY=your_decoding_key_here
# 격자 좌표 (기본값: 서울)
VITE_WEATHER_NX=60
VITE_WEATHER_NY=127
# 에어코리아 측정소명 (기본값: 종로구)
VITE_AIR_STATION_NAME=종로구

# 5. Firebase (FCM) 설정
# ------------------------------------------------------------------------------
# Firebase 콘솔에서 프로젝트 설정 → 일반 → 웹 앱 → SDK 설정
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Firebase 콘솔 → Cloud Messaging → 웹 푸시 인증서 키
VITE_FIREBASE_VAPID_KEY=
